---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
    <h1 class="text-center lg:text-8xl text-6xl font-semibold mb-8">Hi, ich bin Maximilian.</h1>
    <div class="flex justify-center gap-4">
      <a
        href="https://github.com/zeronacer"
        target="_blank"
        class="group/icon rounded-full p-4 hover:bg-primary transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-12 aspect-square stroke-2 fill-none stroke-primary group-hover/icon:stroke-white transition-colors"
          ><path
            d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
          ></path></svg
        >
      </a>
      <a
        href="www.linkedin.com/in/maximilian-grabau"
        target="_blank"
        class="group/icon rounded-full p-4 hover:bg-primary transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-12 aspect-square stroke-2 fill-none stroke-primary group-hover/icon:stroke-white transition-colors"
          ><path
            d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
          ></path><rect x="2" y="9" width="4" height="12"></rect><circle
            cx="4"
            cy="4"
            r="2"></circle></svg
        >
      </a>
    </div>
  </div>
</BaseLayout>
